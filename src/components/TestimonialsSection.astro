---
const testimonials = [
  {
    name: 'Game Developer',
    role: 'Indie Studio',
    photo: 'https://randomuser.me/api/portraits/men/32.jpg',
    quote:
      'SGC is the perfect place to connect with fellow game developers from the region. The talks are practical and the networking is invaluable.',
  },
  {
    name: 'Artist',
    role: 'Game Studio',
    photo: 'https://randomuser.me/api/portraits/women/76.jpg',
    quote:
      'I came looking for inspiration and left with new friends, new ideas, and a much better understanding of the business side of games.',
  },
  {
    name: 'Producer',
    role: 'Publishing',
    photo: 'https://randomuser.me/api/portraits/men/58.jpg',
    quote:
      'A fantastic one-day event that packs in everything you need — from technical deep dives to career advice. Highly recommended.',
  },
  {
    name: 'Designer',
    role: 'Mobile Games',
    photo: 'https://randomuser.me/api/portraits/women/65.jpg',
    quote:
      'The casual atmosphere makes it easy to approach anyone. I met representatives from dozens of companies and learned so much about the industry.',
  },
  {
    name: 'Programmer',
    role: 'AAA Studio',
    photo: 'https://randomuser.me/api/portraits/women/33.jpg',
    quote:
      'Great talks that challenge your thinking and give you practical insights. A must-attend for anyone in game development in the region.',
  },
  {
    name: 'Business Dev',
    role: 'Game Publisher',
    photo: 'https://randomuser.me/api/portraits/women/12.jpg',
    quote:
      'Whether you are a career seeker or a veteran, SGC has something for everyone. The energy is incredible.',
  },
];

const topRow = testimonials.slice(0, 3);
const bottomRow = testimonials.slice(3);
---

<!-- TODO: Uncomment testimonials section when real attendee quotes are available -->


<style>
.testimonials-section { background: #f2f3f5; padding: 2.4rem 0 4.6rem; }
.testimonials-wrap { width: 100%; display: grid; gap: 1rem; }
.testimonials-title { margin: 0; text-align: center; color: #131a20; font-family: "Space Grotesk", "Segoe UI", sans-serif; font-size: clamp(1.8rem, 3.2vw, 2.7rem); line-height: 1.04; letter-spacing: -0.018em; }
.marquee-row { position: relative; overflow: hidden; padding-inline: 0.8rem; }
.marquee-row::before, .marquee-row::after { content: ""; position: absolute; top: 0; width: 56px; height: 100%; z-index: 2; pointer-events: none; }
.marquee-row::before { left: 0; background: linear-gradient(90deg, #f2f3f5, rgba(242, 243, 245, 0)); }
.marquee-row::after { right: 0; background: linear-gradient(270deg, #f2f3f5, rgba(242, 243, 245, 0)); }
.marquee-track { display: flex; gap: 0.9rem; width: max-content; will-change: transform; }
.marquee-track-forward { animation: testimonials-left 24s linear infinite; }
.marquee-track-reverse { animation: testimonials-left 24s linear infinite reverse; }
.testimonial-card { width: clamp(260px, 30vw, 410px); min-height: 210px; background: #eceef2; border: 1px solid #e0e4ea; border-radius: 14px; padding: 1rem 1.05rem; color: #161d24; display: grid; grid-template-rows: auto 1fr auto; }
.quote-mark { margin: 0; color: #3f56f2; font-size: 2.8rem; line-height: 1; font-family: Georgia, "Times New Roman", serif; }
.quote { margin: 0.2rem 0 0; font-size: 1.03rem; line-height: 1.42; color: #222a31; }
.person-row { margin-top: 0.9rem; display: flex; align-items: center; gap: 0.65rem; }
.person-row img { width: 34px; height: 34px; border-radius: 999px; object-fit: cover; }
.name { margin: 0; font-weight: 700; font-size: 1rem; line-height: 1.2; }
.role { margin: 0.15rem 0 0; font-size: 0.8rem; color: #8a919a; }
@keyframes testimonials-left { from { transform: translateX(0); } to { transform: translateX(calc(-50% - 0.45rem)); } }
@media (max-width: 720px) { .testimonial-card { width: clamp(238px, 74vw, 320px); min-height: 200px; } .quote { font-size: 0.97rem; } .marquee-track-forward, .marquee-track-reverse { animation-duration: 28s; } }
@media (prefers-reduced-motion: reduce) { .marquee-track-forward, .marquee-track-reverse { animation: none; } }
</style>
