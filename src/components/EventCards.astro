---
// TODO: Uncomment and update when agenda is finalized
// const dayEvents = [
//   { title: 'Morning Talks', description: '...', date: 'TBD', spots: '...', price: '...' },
// ];
---

<section class="program-stage" id="agenda" aria-labelledby="program-title">
  <div class="program-shell container">
    <h2 id="program-title">Agenda</h2>

    <div class="coming-soon-block">
      <p class="coming-soon-emoji" aria-hidden="true">📋</p>
      <h3>Coming Soon</h3>
      <p>The full conference agenda is being prepared. Check back soon for talk schedules, workshop details, and more.</p>
    </div>
  </div>
</section>

<style>
.program-stage {
  position: relative;
  overflow: hidden;
  background-color: #14232f;
  background-image: linear-gradient(180deg, #14232f 0%, #182833 44%, #1f3444 100%);
  background-size: 130% 130%;
  margin-top: 0;
  padding: 4.6rem 0 3.8rem;
  animation: program-gradient-shift 12.9s ease-in-out infinite alternate;
}

.program-stage::before {
  content: "";
  position: absolute;
  left: 50%;
  top: -140px;
  transform: translateX(-50%);
  width: min(980px, 94vw);
  height: 520px;
  background: repeating-radial-gradient(ellipse at 50% 0%, rgba(218, 227, 234, 0.12) 0 1px, transparent 1px 23px);
  opacity: 0.2;
  pointer-events: none;
}

@keyframes program-gradient-shift {
  0% { background-position: 0% 35%; }
  100% { background-position: 100% 65%; }
}

.program-shell {
  position: relative;
  z-index: 2;
}

.program-shell h2 {
  margin: 0 0 1.6rem;
  text-align: center;
  text-transform: uppercase;
  line-height: 0.95;
  font-size: clamp(2rem, 4.6vw, 4rem);
  color: #f2f4f7;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  font-weight: 500;
}

.coming-soon-block {
  max-width: 600px;
  margin: 0 auto;
  padding: 3rem 2rem;
  text-align: center;
  border: 2px dashed rgba(255, 255, 255, 0.2);
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.05);
}

.coming-soon-emoji {
  margin: 0;
  font-size: 3rem;
}

.coming-soon-block h3 {
  margin: 0.5rem 0 0;
  font-size: 1.8rem;
  color: #f2f4f7;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
}

.coming-soon-block p {
  margin: 0.5rem 0 0;
  color: #cfd7dd;
  font-size: 1.05rem;
  line-height: 1.5;
}

@media (max-width: 980px) {
  .coming-soon-block { padding: 2rem 1.5rem; }
}
</style>
