// TODO: Uncomment and populate when speakers are confirmed
// const displaySpeakers = [
//   {
//     name: 'Speaker Name',
//     role: 'Role',
//     company: 'Company',
//     image: 'https://...',
//   },
// ];
---

<section class="speakers-showcase" id="speakers" aria-labelledby="speakers-title">
  <div class="container speakers-wrap">
    <div class="section-head">
      <div class="section-copy">
        <h2 id="speakers-title">Speakers</h2>
        <p>
          Our speaker lineup is being finalized. Expect talks from game developers, designers, producers, and business leaders from across the region.
        </p>
      </div>
    </div>

    <div class="coming-soon-card">
      <p class="coming-soon-icon" aria-hidden="true">🎙️</p>
      <h3>Coming Soon</h3>
      <p>Speaker announcements are on the way. Stay tuned for the full lineup.</p>
    </div>
  </div>
</section>

<style>
.speakers-showcase {
  background: #f7f6f4;
  position: relative;
  padding: 5.1rem 0 5.5rem;
}

.speakers-wrap {
  width: min(1220px, 94%);
}

.section-head {
  display: block;
  margin-bottom: 1.65rem;
}

.section-copy {
  max-width: 760px;
}

.section-copy h2 {
  margin: 0;
  font-size: clamp(2.2rem, 4.9vw, 4.25rem);
  line-height: 0.92;
  letter-spacing: -0.045em;
  color: #202328;
  font-weight: 500;
  font-family: "Space Grotesk", "IBM Plex Sans", "Segoe UI", sans-serif;
}

.section-copy p {
  margin: 1.05rem 0 0;
  max-width: 50ch;
  color: #31363d;
  font-size: clamp(1.02rem, 1.1vw, 1.18rem);
  line-height: 1.55;
}

.coming-soon-card {
  margin-top: 2rem;
  padding: 3rem 2rem;
  text-align: center;
  border: 2px dashed #d8d6db;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.6);
}

.coming-soon-icon {
  margin: 0;
  font-size: 3rem;
}

.coming-soon-card h3 {
  margin: 0.5rem 0 0;
  font-size: 1.8rem;
  color: #202328;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
}

.coming-soon-card p {
  margin: 0.5rem 0 0;
  color: #555b66;
  font-size: 1.05rem;
}

@media (max-width: 820px) {
  .speakers-showcase { padding: 4rem 0 4.5rem; }
  .section-copy h2 { font-size: clamp(2rem, 7vw, 3.2rem); }
}
</style>
