---
import { speakers } from '../data/speakers';
const displaySpeakers = speakers;
---

<section class="speakers-showcase" id="speakers" aria-labelledby="speakers-title">
  <div class="container speakers-wrap">
    <div class="section-head">
      <div class="section-copy">
        <h2 id="speakers-title">Speakers</h2>
      </div>
    </div>

    <div class="coming-soon-card">
      <p class="coming-soon-emoji" aria-hidden="true">🎙️</p>
      <h3>Coming Soon</h3>
      <p>Speaker announcements are on the way. Stay tuned for the full lineup.</p>
      <a href="https://forms.gle/Pu1PB6qJTeaPp1kM7"
          target="_blank"
          rel="noopener noreferrer"
          class="notify-btn">
          Notify me when speakers are announced →
        </a>
    </div>

    {/* TODO: Uncomment when speakers are confirmed
    <div class="speakers-grid">
      {displaySpeakers.map((speaker) => (
        <a href={`/speakers/${speaker.slug}`} class="speaker-card">
          <div class="speaker-img-wrap">
            <img src={speaker.image} alt={speaker.name} class="speaker-img" />
          </div>
          <div class="speaker-info">
            <p class="speaker-name">{speaker.name}</p>
            <p class="speaker-role">{speaker.role}</p>
            <p class="speaker-company">{speaker.company}</p>
          </div>
        </a>
      ))}
    </div>
    */}
  </div>
</section>

<style>
.speakers-showcase {
  background: #f7f6f4;
  position: relative;
  padding: 5.1rem 0 5rem;
}

.speakers-wrap {
  width: min(1220px, 94%);
}

.section-head {
  display: block;
  margin-bottom: 2.5rem;
  text-align: center;
}

.section-copy {
  max-width: 760px;
  margin: 0 auto;
}

.section-copy h2 {
  margin: 0;
  font-size: clamp(2.2rem, 4.9vw, 4.25rem);
  line-height: 0.92;
  letter-spacing: -0.045em;
  font-weight: 500;
  font-family: "Space Grotesk", "IBM Plex Sans", "Segoe UI", sans-serif;
  background: linear-gradient(90deg, #202328 0%, #ff4d10 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-copy p {
  margin: 1.05rem 0 0;
  max-width: 50ch;
  color: #31363d;
  font-size: clamp(1.02rem, 1.1vw, 1.18rem);
  line-height: 1.55;
}

.coming-soon-card {
  border: 2px dashed #999;
  background: #fff;
  border-radius: 18px;
  max-width: 600px;
  margin: 0 auto;
  padding: 3rem 2rem;
}

.coming-soon-emoji {
  margin: 0;
  font-size: 3rem;
  text-align: center;
}

.coming-soon-card h3 {
  margin: 0.5rem 0 0;
  font-size: 1.8rem;
  color: #202328;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  text-align: center;
}

.coming-soon-card p {
  margin: 0.5rem 0 0;
  color: #555b66;
  font-size: 1.05rem;
  text-align: center;
}

.speakers-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1.5rem;
}

.speaker-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  border: none;
  text-decoration: none;
  color: inherit;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.06);
}

.speaker-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.14), 0 2px 8px rgba(0,0,0,0.08);
}

.speaker-img-wrap {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: #e8e6e1;
}

.speaker-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.speaker-info {
  padding: 1rem 1.1rem 1.2rem;
  text-align: center;
}

.speaker-name {
  margin: 0;
  font-size: 1.05rem;
  font-weight: 600;
  color: #202328;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
}

.speaker-role {
  margin: 0.2rem 0 0;
  font-size: 0.88rem;
  color: #555b66;
}

.speaker-company {
  margin: 0.15rem 0 0;
  font-size: 0.82rem;
  color: #ff6f2c;
  font-weight: 500;
}

.notify-btn {
  display: block;
  width: fit-content;
  margin: 1.5rem auto 0;
  padding: 0.75rem 1.75rem;
  background: #ff4d10;
  color: #fff;
  font-weight: 700;
  font-size: 1rem;
  border-radius: 999px;
  text-decoration: none;
  transition: background 0.15s;
}

.notify-btn:hover {
  background: #e03d00;
}

@media (max-width: 1100px) {
  .speakers-grid { grid-template-columns: repeat(4, 1fr); }
}

@media (max-width: 820px) {
  .speakers-showcase { padding: 4rem 0 4.5rem; }
  .section-copy h2 { font-size: clamp(2rem, 7vw, 3.2rem); }
  .speakers-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
}

@media (max-width: 520px) {
  .speakers-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>