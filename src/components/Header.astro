---
const links = [
  { label: 'Program', href: '#lineup' },
  { label: 'Lineup', href: '#lineup' },
  { label: 'Leadership Events', href: '#lineup', badge: 'NEW' },
  { label: 'Partners', href: '#lineup' },
];
---

<header class="site-header" id="top">
  <div class="container header-wrap">
    <a href="/" class="brand-mark" aria-label="ARTHAM AI Summit home">
      <img class="brand-logo" src="/artham.png" alt="ARTHAM" />
    </a>

    <nav aria-label="Main navigation" class="main-nav">
      <ul class="nav-list">
        {links.map((link) => (
          <li>
            <a href={link.href} class={link.badge ? 'nav-link-with-badge' : ''}>
              {link.label}
              {link.badge && <span class="nav-badge">{link.badge}</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-cta">
      <a href="https://ti.to/ae-events/ae-conference/with/conference-pass" class="btn-primary">Tickets</a>
    </div>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #f7f6f4;
  border-bottom: none;
  width: 100%;
  pointer-events: auto;
}

.header-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 1.2rem;
  width: 100%;
  max-width: unset;
}

.brand-mark {
  width: 38px;
  height: 38px;
  border-radius: 999px;
  background: rgb(255 255 255 / 92%);
  border: 1px solid rgba(255, 255, 255, 0.5);
  display: grid;
  place-items: center;
  text-decoration: none;
  box-shadow: 0 8px 18px rgba(0, 0, 0, 0.25);
}

.brand-logo {
  width: 22px;
  height: 22px;
  object-fit: contain;
  display: block;
}

.main-nav {
  flex: 1;
  margin: 0 1rem;
}

.nav-list {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 0.35rem;
  align-items: center;
}

.nav-list li a {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.58rem 1rem;
  border-radius: 999px;
  background: #ffffff;
  color: #202225;
  text-decoration: none;
  font-weight: 700;
  font-size: 0.9rem;
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.5), 0 8px 18px rgba(0, 0, 0, 0.08);
  transition: all 0.2s ease;
  border: 1px solid transparent;
}

.nav-list li a:hover {
  background: #f6f1e8;
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.5), 0 8px 18px rgba(0, 0, 0, 0.12);
}

.nav-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  background: #ff4f12;
  color: white;
  padding: 0.2rem 0.45rem;
  border-radius: 3px;
  line-height: 1;
}

.header-cta {
  display: flex;
  gap: 0.8rem;
  align-items: center;
}

.btn-primary {
  padding: 0.7rem 1.4rem;
  background: #ff5a14;
  color: white;
  text-decoration: none;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.9rem;
  box-shadow: 0 4px 12px rgba(255, 79, 18, 0.3);
  transition: all 0.2s ease;
  border: none;
  cursor: pointer;
  backdrop-filter: none;
}

.btn-primary:hover {
  background: #e63f0c;
  box-shadow: 0 6px 16px rgba(255, 79, 18, 0.4);
  transform: translateY(-1px);
}

@media (max-width: 768px) {
  .header-wrap {
    gap: 1rem;
  }

  .main-nav {
    margin: 0 1rem;
    flex: 1;
  }

  .nav-list {
    gap: 0.3rem;
  }

  .nav-list li a {
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
  }

  .btn-primary {
    padding: 0.6rem 1rem;
    font-size: 0.85rem;
  }
}
</style>
