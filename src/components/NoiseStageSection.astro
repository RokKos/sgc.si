---
const aftermovieYouTubeId = 'JZ9CqWAJoYg';
const aftermovieEmbedUrl = `https://www.youtube.com/embed/${aftermovieYouTubeId}?autoplay=1&mute=1&loop=1&playlist=${aftermovieYouTubeId}&controls=1&modestbranding=1&rel=0`;
const aftermovieWatchUrl = `https://www.youtube.com/watch?v=${aftermovieYouTubeId}`;
---

<section class="noise-stage" id="about" aria-labelledby="noise-stage-title">
  <div class="noise-shell container">
    <span class="noise-kicker reveal-line" style="--reveal-delay: 0s;">About The Conference</span>
    <h2 id="noise-stage-title" class="noise-title reveal-line" style="--reveal-delay: 0.12s;">
      Where Game Developers
      <span>Come Together</span>
    </h2>
    <p class="noise-copy reveal-line" style="--reveal-delay: 0.24s;">
      Slovenia Games Conference is a one-day event where industry professionals and enthusiasts celebrate the games industry as a whole. Whether you're a programmer, artist, designer, business person, producer, career seeker, or recruiter — you'll find what you're looking for.
    </p>

    <article class="video-card" aria-label="Conference highlights">
      <iframe
        class="video-frame"
        src={aftermovieEmbedUrl}
        title="Conference highlights"
        loading="lazy"
        aria-label="Conference highlights video"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
      <a class="video-pill" href={aftermovieWatchUrl} target="_blank" rel="noopener noreferrer" aria-label="Watch conference highlights on YouTube">Watch Highlights</a>
    </article>

    <section class="brand-showcase" aria-labelledby="brand-showcase-title">
      <p id="brand-showcase-title" class="brand-note reveal-line" style="--reveal-delay: 0.36s;">What You'll Experience</p>

      <div class="feature-grid reveal-line" style="--reveal-delay: 0.48s;">
        <div class="feature-item">
          <span class="feature-icon">🎮</span>
          <p>Talks & Panels</p>
        </div>
        <div class="feature-item">
          <span class="feature-icon">🤝</span>
          <p>Networking</p>
        </div>
        <div class="feature-item">
          <span class="feature-icon">💼</span>
          <p>Career Opportunities</p>
        </div>
        <div class="feature-item">
          <span class="feature-icon">🎨</span>
          <p>Game Showcases</p>
        </div>
        <div class="feature-item">
          <span class="feature-icon">📈</span>
          <p>Business Insights</p>
        </div>
      </div>
    </section>
  </div>

  <div class="decor decor-left" aria-hidden="true"></div>
  <div class="decor decor-right" aria-hidden="true"></div>
  <div class="cross cross-left" aria-hidden="true"></div>
  <div class="cross cross-right" aria-hidden="true"></div>
  <div class="noise-dot noise-dot-a" aria-hidden="true"></div>
  <div class="noise-dot noise-dot-b" aria-hidden="true"></div>
  <div class="noise-arc noise-arc-a" aria-hidden="true"></div>
  <div class="noise-arc noise-arc-b" aria-hidden="true"></div>
</section>

<script>
  const noiseStage = document.querySelector('.noise-stage');
  if (noiseStage) {
    const stageObserver = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          noiseStage.classList.add('is-visible');
        }
      },
      { threshold: 0.25 }
    );
    stageObserver.observe(noiseStage);
  }
</script>

<style>
.noise-stage {
  position: relative;
  overflow: hidden;
  background-color: #182833;
  background-image: linear-gradient(180deg, #182833 0%, #1f3444 42%, #14232f 100%);
  background-size: 130% 130%;
  color: #eef3f6;
  margin-top: -340px;
  padding: 260px 0 3.8rem;
  clip-path: polygon(
    0 16%, 8% 14%, 22% 12%, 36% 10%, 50% 9%, 64% 10%, 78% 12%, 92% 14%, 100% 16%, 100% 100%, 0 100%
  );
  animation: gradient-shift 12.9s ease-in-out infinite alternate;
}

.noise-shell {
  position: relative;
  z-index: 2;
  padding-top: 5.6rem;
  text-align: center;
}

.noise-kicker {
  text-transform: uppercase;
  letter-spacing: 0.3em;
  font-size: 0.88rem;
  color: #d2d9dd;
  font-weight: 700;
}

.noise-title {
  margin: 0.7rem auto 0;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  font-size: clamp(2rem, 5vw, 3.7rem);
  line-height: 1.02;
  text-transform: uppercase;
  font-weight: 500;
  max-width: 15ch;
}

.noise-title span { color: #ff4f12; }

.noise-copy {
  margin: 0.85rem auto 0;
  font-size: clamp(1rem, 1.55vw, 1.75rem);
  color: #d7dde2;
  max-width: 55ch;
}

.video-card {
  margin: 1.6rem auto 0;
  max-width: min(920px, 92%);
  border: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
  background: rgba(0, 0, 0, 0.3);
  padding: 0.6rem;
  position: relative;
}

.video-frame {
  display: block;
  width: 100%;
  aspect-ratio: 16 / 9;
  border: 0;
}

.video-pill {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 3;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  background: rgba(17, 17, 17, 0.86);
  color: #fff;
  text-decoration: none;
  border-radius: 999px;
  padding: 0.72rem 1.2rem;
  font-weight: 700;
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.26);
}

.reveal-line {
  opacity: 0;
  transform: translate3d(0, 18px, 0);
  filter: blur(8px);
  transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.2, 0.75, 0.2, 1), filter 0.8s ease;
  transition-delay: var(--reveal-delay, 0s);
  will-change: opacity, transform, filter;
}

.noise-stage.is-visible .reveal-line {
  opacity: 1;
  transform: translate3d(0, 0, 0);
  filter: blur(0);
}

.brand-note {
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 2rem;
  color: #d7dce0;
  font-weight: 700;
}

.brand-showcase {
  position: relative;
  margin: 3.2rem auto 0;
  padding: 1.1rem 0 0.25rem;
  max-width: 980px;
}

.feature-grid {
  margin-top: 1.55rem;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

.feature-icon {
  font-size: 2rem;
}

.feature-item p {
  margin: 0;
  color: #eef4f8;
  font-weight: 700;
  font-size: 1rem;
}

.decor {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
  z-index: 1;
}

.decor-left {
  width: 500px; height: 500px;
  border: 26px solid rgba(255, 74, 17, 0.75);
  left: -260px; top: 370px;
  box-shadow: inset 0 0 0 10px rgba(255, 255, 255, 0.74), inset 0 0 0 44px rgba(0, 0, 0, 0.4);
  animation: float-left 6.4s ease-in-out infinite;
}

.decor-right {
  width: 580px; height: 580px;
  border: 38px solid rgba(255, 74, 17, 0.74);
  right: -200px; top: 150px;
  box-shadow: inset 0 0 0 10px rgba(255, 255, 255, 0.28);
  animation: float-right 7.9s ease-in-out infinite;
}

.cross { position: absolute; width: 95px; height: 95px; opacity: 0.6; z-index: 1; }
.cross::before, .cross::after { content: ""; position: absolute; background: rgba(255, 74, 17, 0.72); }
.cross::before { width: 2px; height: 100%; left: 50%; top: 0; }
.cross::after { height: 2px; width: 100%; top: 50%; left: 0; }
.cross-left { left: 50px; bottom: 120px; animation: cross-pulse 3.3s ease-in-out infinite; }
.cross-right { right: 70px; top: 260px; animation: cross-pulse 3.7s ease-in-out infinite; }

.noise-dot { position: absolute; border-radius: 999px; pointer-events: none; z-index: 1; }
.noise-dot-a { width: 18px; height: 18px; left: 22%; top: 190px; background: rgba(255, 255, 255, 0.82); box-shadow: 0 0 0 10px rgba(255, 79, 18, 0.18); animation: dot-bob 3.6s ease-in-out infinite; }
.noise-dot-b { width: 28px; height: 28px; right: 19%; bottom: 170px; background: rgba(255, 79, 18, 0.9); box-shadow: 0 0 0 12px rgba(255, 255, 255, 0.08); animation: dot-bob 4.3s ease-in-out infinite reverse; }

.noise-arc { position: absolute; pointer-events: none; z-index: 1; border: 3px solid rgba(255, 255, 255, 0.22); border-radius: 999px; }
.noise-arc-a { width: 180px; height: 180px; right: 24%; top: 120px; border-left-color: transparent; border-bottom-color: transparent; transform: rotate(14deg); animation: arc-sway 5.6s ease-in-out infinite; }
.noise-arc-b { width: 120px; height: 120px; left: 10%; bottom: 90px; border-right-color: transparent; border-top-color: transparent; transform: rotate(-18deg); opacity: 0.45; animation: arc-sway 5s ease-in-out infinite reverse; }

@keyframes gradient-shift { 0% { background-position: 0% 35%; } 100% { background-position: 100% 65%; } }
@keyframes float-left { 0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); } 50% { transform: translate3d(10px, -10px, 0) rotate(2deg); } }
@keyframes float-right { 0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg); } 50% { transform: translate3d(-12px, 12px, 0) rotate(-2deg); } }
@keyframes cross-pulse { 0%, 100% { opacity: 0.45; transform: scale(1); } 50% { opacity: 0.85; transform: scale(1.06); } }
@keyframes dot-bob { 0%, 100% { transform: translate3d(0, 0, 0) scale(1); } 50% { transform: translate3d(0, -10px, 0) scale(1.08); } }
@keyframes arc-sway { 0%, 100% { transform: translate3d(0, 0, 0) rotate(14deg); } 50% { transform: translate3d(0, -8px, 0) rotate(8deg); } }

@media (max-width: 900px) {
  .noise-stage {
    margin-top: -120px; padding-top: 120px;
    clip-path: polygon(0 14%, 8% 12%, 22% 10%, 36% 8%, 50% 7%, 64% 8%, 78% 10%, 92% 12%, 100% 14%, 100% 100%, 0 100%);
  }
  .noise-shell { padding-top: 4.6rem; }
  .decor-right { width: 360px; height: 360px; border-width: 24px; right: -140px; top: 260px; }
  .decor-left { width: 320px; height: 320px; border-width: 16px; left: -160px; top: 460px; }
  .brand-note { font-size: 1.3rem; letter-spacing: 0.14em; }
  .feature-grid { gap: 1rem; }
  .noise-dot-a { left: 12%; top: 165px; width: 14px; height: 14px; }
  .noise-dot-b { right: 12%; bottom: 150px; width: 22px; height: 22px; }
  .noise-arc-a { width: 128px; height: 128px; right: 14%; top: 140px; }
  .noise-arc-b { width: 88px; height: 88px; left: 4%; bottom: 70px; }
}

@media (prefers-reduced-motion: reduce) {
  .reveal-line { opacity: 1; transform: none; filter: none; transition: none; }
}
</style>
