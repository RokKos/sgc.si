---
import Layout from '../../layouts/Layout.astro';
import { speakers } from '../../data/speakers';

export function getStaticPaths() {
  return speakers.map((speaker) => ({
    params: { slug: speaker.slug },
    props: { speaker },
  }));
}

const { speaker } = Astro.props;
---

<Layout title={`${speaker.name} — SGC 2026`}>
  <main class="speaker-page">
    <div class="speaker-hero-bg">
      <div class="hero-overlay"></div>
      <div class="container speaker-wrap">
        <div class="speaker-hero">
          <img src={speaker.image} alt={speaker.name} class="speaker-photo" />
          <div class="speaker-details">
            <p class="speaker-company">{speaker.company}</p>
            <h1 class="speaker-name">{speaker.name}</h1>
            <p class="speaker-role">{speaker.role}</p>
            <p class="speaker-bio">{speaker.bio}</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
.speaker-page {
  min-height: 100vh;
  background: #0f1419;
}

.speaker-hero-bg {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background-image: url('/coming-soon-bg.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  padding: 4rem 0 6rem;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(0, 0, 0, 0.35), rgba(0, 0, 0, 0.78)),
    radial-gradient(circle at center, rgba(255, 79, 18, 0.22), transparent 55%);
  z-index: 1;
}

.speaker-wrap {
  position: relative;
  z-index: 2;
  width: min(900px, 94%);
  margin: 0 auto;
}

.back-link {
  display: inline-block;
  margin-bottom: 2.5rem;
  font-size: 0.95rem;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: color 0.15s;
}

.back-link:hover {
  color: #ff6f2c;
}

.speaker-hero {
  display: flex;
  gap: 3rem;
  align-items: flex-start;
  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 18px;
  padding: 2.5rem;
}

.speaker-photo {
  width: 220px;
  height: 220px;
  object-fit: cover;
  border-radius: 12px;
  flex-shrink: 0;
}

.speaker-details {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.speaker-company {
  margin: 0;
  font-size: 0.9rem;
  font-weight: 500;
  color: #ff6f2c;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.speaker-name {
  margin: 0;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 500;
  letter-spacing: -0.03em;
  color: #ffffff;
  font-family: "Space Grotesk", "Segoe UI", sans-serif;
  line-height: 1;
}

.speaker-role {
  margin: 0;
  font-size: 1.05rem;
  color: rgba(255,255,255,0.6);
}

.speaker-bio {
  margin: 1rem 0 0;
  font-size: 1.05rem;
  line-height: 1.65;
  color: rgba(255,255,255,0.8);
}

@media (max-width: 640px) {
  .speaker-hero {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .speaker-photo {
    width: 160px;
    height: 160px;
  }
}
</style>