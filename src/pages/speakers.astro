---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Speakers - Slovenia Games Conference 2026">
  <Header />

  <main class="speakers-page">
    <section class="speakers-hero">
      <div class="container speakers-hero-inner">
        <p class="eyebrow">Slovenia Games Conference 2026</p>
        <h1>Speakers</h1>
        <p>
          Our speaker lineup is being finalized. Check back soon for the full list of game developers, designers, and industry leaders.
        </p>
      </div>
    </section>

    <section class="speakers-grid-section" aria-label="Speaker announcements">
      <div class="container coming-soon-wrap">
        <div class="coming-soon-card">
          <p class="coming-soon-emoji" aria-hidden="true">🎙️</p>
          <h2>Coming Soon</h2>
          <p>Speaker announcements are on the way.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
.speakers-page { background: #f7f6f4; min-height: 100vh; }
.speakers-hero { padding: 7.2rem 0 2.2rem; }
.speakers-hero-inner { width: min(1120px, 94%); }
.eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.16em; font-size: 0.78rem; font-weight: 700; color: #6a7278; }
.speakers-hero h1 { margin: 0.45rem 0 0; font-size: clamp(2.3rem, 6vw, 4.5rem); line-height: 0.94; letter-spacing: -0.03em; color: #1f2429; font-family: "Space Grotesk", "Segoe UI", sans-serif; }
.speakers-hero p { margin: 0.95rem 0 0; max-width: 55ch; color: #343b41; font-size: clamp(1rem, 1.25vw, 1.14rem); line-height: 1.55; }
.speakers-grid-section { padding: 0 0 4.6rem; }
.coming-soon-wrap { width: min(1120px, 94%); }
.coming-soon-card { padding: 3rem 2rem; text-align: center; border: 2px dashed #d8d6db; border-radius: 18px; background: rgba(255, 255, 255, 0.6); }
.coming-soon-emoji { margin: 0; font-size: 3rem; }
.coming-soon-card h2 { margin: 0.5rem 0 0; font-size: 1.8rem; color: #202328; font-family: "Space Grotesk", "Segoe UI", sans-serif; }
.coming-soon-card p { margin: 0.5rem 0 0; color: #555b66; font-size: 1.05rem; }
</style>
